        "jsCode": "const doc = $json;\nconst tagsResponse = $items('Paperless - Tags holen', 0, 0)[0].json;\nconst docTypesResponse = $items('Paperless - Dokumenttypen holen', 0, 0)[0].json;\nconst config = $items('Konfiguration', 0, 0)[0].json;\nconst tags = (tagsResponse.results || []).map(t => ({ id: t.id, name: t.name }));\nconst docTypes = (docTypesResponse.results || []).map(d => ({ id: d.id, name: d.name }));\nconst rawContent = doc.content || doc.notes || '';\nconst content = String(rawContent).slice(0, config.max_content_chars || 12000);\nconst systemPrompt = 'Du analysierst Paperless-Dokumente. Gib valides JSON zurueck ohne Markdown. Erzeuge Titel, waehle document_type_id und tag_ids.';\nconst userPrompt = JSON.stringify({ id: doc.id, title: doc.title, original_file_name: doc.original_file_name, created: doc.created, docTypes, tags, content });\nreturn { json: { doc_id: doc.id, current_title: doc.title || '', current_tags: doc.tags || [], current_document_type: doc.document_type || null, paperless_url: config.paperless_url, paperless_token: config.paperless_token, systemPrompt, userPrompt } };"
