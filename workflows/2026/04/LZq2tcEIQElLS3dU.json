    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const doc = $json;\nconst tagsResponse = $items('Paperless - Tags holen', 0, 0)[0].json;\nconst docTypesResponse = $items('Paperless - Dokumenttypen holen', 0, 0)[0].json;\nconst config = $items('Konfiguration', 0, 0)[0].json;\n\nconst tags = (tagsResponse.results || []).map(t => ({ id: t.id, name: t.name }));\nconst docTypes = (docTypesResponse.results || []).map(d => ({ id: d.id, name: d.name }));\n\nconst rawContent = doc.content || doc.notes || '';\nconst content = String(rawContent).slice(0, config.max_content_chars || 12000);\n\nconst systemPrompt = `Du analysierst Paperless-Dokumente.\\nGib ausschließlich valides JSON zurück. Keine Markdown-Codeblöcke.\\n\\nZiel:\\n- Erzeuge einen kurzen, sauberen deutschen Titel\\n- Wähle genau eine passende document_type_id aus der Liste\\n- Wähle 0 bis 8 passende tag_ids aus der Liste\\n- Nutze nur IDs, die in den Listen vorkommen\\n- Wenn unsicher, document_type_id = null und tag_ids = []\\n\\nJSON-Schema:\\n{\\n  \\\"title\\\": \\\"string\\\",\\n  \\\"document_type_id\\\": 123 oder null,\\n  \\\"tag_ids\\\": [1,2,3]\\n}`;\n\nconst userPrompt = `Dokument-Metadaten:\\n- ID: ${doc.id}\\n- Bisheriger Titel: ${doc.title || ''}\\n- Originaldateiname: ${doc.original_file_name || ''}\\n- Erstellungsdatum: ${doc.created || ''}\\n\\nVerfügbare Dokumenttypen:\\n${JSON.stringify(docTypes, null, 2)}\\n\\nVerfügbare Tags:\\n${JSON.stringify(tags, null, 2)}\\n\\nDokumentinhalt:\\n${content}`;\nreturn {\n  json: {\n    doc_id: doc.id,\n    current_title: doc.title || '',\n    current_tags: doc.tags || [],\n    current_document_type: doc.document_type || null,\n\n    paperless_url: config.paperless_url,\n    paperless_token: config.paperless_token,\n\n    ai_base_url: config.ai_base_url,\n    ai_api_key: config.ai_api_key,\n    ai_model: config.ai_model,\n\n    systemPrompt,\n    userPrompt\n  }\n};\n\n"
      },
