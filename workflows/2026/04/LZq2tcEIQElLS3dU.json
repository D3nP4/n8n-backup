      {
        "parameters": {
          "jsCode": "const now = new Date();\nconst folderName = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');\nreturn $input.all().map(item => { const title = item.json.title || item.json.original_file_name || 'Dokument-' + item.json.id; const safeTitle = String(title).replace(/[/:*?\"<>|]/g, '-').replace(/\\s+/g, ' ').trim(); return { json: { id: item.json.id, title: safeTitle, folderName, fileName: safeTitle.toLowerCase().endsWith('.pdf') ? safeTitle : safeTitle + '.pdf' } }; });"
