          "jsCode": "const text = $json.output?.[0]?.content?.[0]?.text || '';\nconst ai = JSON.parse(text);\n\nconst previous = $('KI Prompt bauen').first().json;\n\nconst tagIds = Array.from(new Set([1, ...(ai.tag_ids || [])]));\n\nreturn {\n  json: {\n    doc_id: previous.doc_id,\n    paperless_url: previous.paperless_url,\n    paperless_token: previous.paperless_token,\n\n    title: ai.title,\n    tag_ids: tagIds\n  }\n};"
