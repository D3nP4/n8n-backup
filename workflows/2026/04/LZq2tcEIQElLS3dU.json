      {
        "parameters": {
          "jsCode": "const now = new Date();\nconst folderName = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;\n\nreturn $input.all().map(item => {\n  const title =\n    item.json.title ||\n    item.json.ai_result?.title ||\n    item.json.original_file_name ||\n    item.json.fileName ||\n    `Dokument-${item.json.id}`;\n\n  const safeTitle = String(title)\n    .replace(/[\\\\/:*?\"<>|]/g, '-')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\n  return {\n    json: {\n      id: item.json.id,\n      title: safeTitle,\n      folderName,\n      fileName: safeTitle.toLowerCase().endsWith('.pdf')\n        ? safeTitle\n        : `${safeTitle}.pdf`\n    }\n  };\n});"
        },
