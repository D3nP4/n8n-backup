      "parameters": {
        "jsCode": "const d = items[0].json.daily;\nconst code = d.weathercode[1];\nconst temp = d.temperature_2m_max[1];\nconst rain = d.precipitation_sum[1];\nconst goodCodes = [0,1,2];\nconst good = goodCodes.includes(code) && temp >= 15 && rain < 1;\nconst icons = {0:'☀️',1:'🌤️',2:'⛅',3:'☁️',45:'🌫️',48:'🌫️',51:'🌦️',61:'🌧️',80:'🌦️',95:'⛈️'};\nconst icon = icons[code] || '🌡️';\nreturn [{ json: { good, code, temp: Math.round(temp), rain: Math.round(rain*10)/10, icon } }];"
      },
