    {
      "parameters": {
        "jsCode": "const weather = $('Wetter prüfen').first().json;\nlet route = null;\ntry {\n  const tours = items[0].json._embedded?.tours?.items || items[0].json.items || [];\n  if (tours.length) {\n    const pick = tours[Math.floor(Math.random() * Math.min(tours.length, 10))];\n    route = { name: pick.name, km: Math.round((pick.distance||0)/100)/10, elevation: Math.round(pick.elevation_up||0), url: `https://www.komoot.de/tour/${pick.id}` };\n  }\n} catch(e) {}\nconst sportLabel = weather.temp >= 22 ? 'Rennrad' : 'MTB oder Rennrad';\nlet text = `🚴 *Morgen perfektes Fahrrad-Wetter!*\\n\\n${weather.icon} ${weather.temp}°C · ${weather.rain} mm Regen\\n\\nIdeal für: ${sportLabel}`;\nif (route) text += `\\n\\n📍 *Route-Vorschlag:*\\n${route.name}\\n${route.km} km · ↑ ${route.elevation} m\\n${route.url}`;\nreturn [{ json: { text } }];"
      },
