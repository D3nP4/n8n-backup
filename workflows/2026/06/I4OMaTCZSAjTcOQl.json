      "name": "Produkte parsen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1720,
        300
      ],
      "parameters": {
        "jsCode": "\nconst text = $json.content?.[0]?.text || '';\nconst match = text.match(/\\[\\s*\\{[\\s\\S]*?\\}\\s*\\]/);\nif (!match) return [{json:{products:[], raw: text}}];\nlet products;\ntry { products = JSON.parse(match[0]); } catch(e) { return [{json:{products:[], raw: text}}]; }\nreturn [{json: {products, chatId: $('Telegram: Foto empfangen').first().json.message.chat.id}}];\n"
      }
    },
