      "name": "Updates verarbeiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        380,
        400
      ],
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst updates = ($input.first().json.result || []);\n\nif (updates.length > 0) {\n  staticData.telegramOffset = updates[updates.length - 1].update_id + 1;\n}\n\n// Only messages (not edits etc.)\nconst messages = updates\n  .filter(u => u.message)\n  .map(u => ({json: {message: u.message}}));\n\nif (messages.length === 0) return [{json: {noMessages: true}}];\nreturn messages;"
      }
