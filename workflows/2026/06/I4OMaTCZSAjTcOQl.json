      {
        "id": "build-claude",
        "name": "Claude Anfrage bauen",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1280,
          300
        ],
        "parameters": {
          "jsCode": "\nconst item = $input.first();\nconst bin = item.binary?.data;\nif (!bin) throw new Error('Kein Bild gefunden');\nconst base64 = bin.data;\nconst mime   = bin.mimeType || 'image/jpeg';\n\nreturn [{json: {\n  model: 'claude-haiku-4-5-20251001',\n  max_tokens: 1024,\n  messages: [{\n    role: 'user',\n    content: [\n      {type:'image', source:{type:'base64', media_type: mime, data: base64}},\n      {type:'text', text:'Analysiere diesen Einkaufszettel (handgeschrieben oder gedruckt). Gib AUSSCHLIESSLICH ein JSON-Array zurück, kein anderer Text: [{\"name\":\"Produktname\",\"quantity\":Menge,\"unit\":\"Einheit\"}]. Erkenne alle Produkte und Mengen. Verwende als unit: Stück, g, kg, ml, L, Pack, Bund. Wenn keine Menge erkennbar: quantity:1.'}\n    ]\n  }]\n}}];\n"
        }
      },
      {
        "id": "claude-api",
        "name": "Claude Vision API",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4,
        "position": [
          1500,
          300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.anthropic.com/v1/messages",
          "authentication": "predefinedCredentialType",
          "nodeCredentialType": "anthropicApi",
          "sendBody": true,
          "contentType": "json",
          "body": "={{ JSON.stringify($json) }}",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "anthropic-version",
                "value": "2023-06-01"
              }
            ]
          },
          "options": {}
