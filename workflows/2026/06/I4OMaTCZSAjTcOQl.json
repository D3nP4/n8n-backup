              "value": "OGILHrpLi2wVQRb3ZvilbeyKR9oA3PRm6X1REEJe7MRjOfYMy3"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "match-products",
      "name": "Produkte zuordnen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        300
      ],
      "parameters": {
        "jsCode": "\nconst grocyList = Array.isArray($json) ? $json : ($json.data || []);\nconst parseNode = $('Produkte parsen').first().json;\nconst products  = parseNode.products || [];\nconst chatId    = parseNode.chatId;\n\nconst unitMap = {Stück:2, Piece:2, Pack:3, Packung:3, g:2, kg:2, ml:2, L:2};\n\nreturn products.map(p => {\n  const nameLow = p.name.toLowerCase();\n  const match   = grocyList.find(g =>\n    g.name.toLowerCase() === nameLow ||\n    g.name.toLowerCase().includes(nameLow) ||\n    nameLow.includes(g.name.toLowerCase())\n  );\n  return {json: {\n    name:      p.name,\n    quantity:  p.quantity || 1,\n    unit:      p.unit || 'Stück',\n    productId: match ? match.id : null,\n    qu_id:     match ? match.qu_id_stock : 2,\n    chatId\n  }};\n});\n"
      }
    },
